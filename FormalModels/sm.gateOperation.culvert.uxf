    </coordinates>
    <panel_attributes>*1.FlowBlocked*

gate = G2[Gate] self

update the capacity attributes

if 'there exists vesselGroup
    wanting to cross the gate'
then 
    signal gate equalizationAchieved
else
    nextCulvert = 'culvert of next gate'
    signal nextCulvert capacityVerified
valign=top
halign=left
//style=autoresize
bg=cyan</panel_attributes>
