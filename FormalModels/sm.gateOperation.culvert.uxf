    <panel_attributes>*5.VerifyingTransferCapacity*

if 'already equalized' then 
    signal self alreadyEqual
elseif 'next chamber has transfer capacity' then 
    signal self capacityVerified
else 
    nextCulvert = 'next gate's culvert'
    signal nextCulvert equalizationRequested
valign=top
halign=left
//style=autoresize
bg=cyan</panel_attributes>
